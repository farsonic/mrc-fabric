#!/usr/bin/env python3
"""
mrc-agent — the host-side virtual NIC for an MRC-capable endpoint.

Maintains a persistent SSE subscription to the mrc-fabric controller and
programs the host dataplane to match the served EV profile in real time:

  - lifecycle of the `mrc0` dummy interface (the host's tenant identity surface)
  - the host's tenant IPv6 address lives on mrc0 (decoupled from any underlay)
  - seg6 encap routes to peer tenant addresses (single-path OR ECMP multipath)
  - L4 multipath hashing sysctl
  - posts underlay byte counters back to the controller for real telemetry
  - writes its full state to a local state file so `mrc-agent status` (and any
    other tool on the host) can see everything in one place, instantly

Any application sending to a peer tenant address picks up the agent's current
state — apps stay MRC-unaware; the agent is the MRC endpoint.

Commands:
  mrc-agent run     --host H --controller URL --tenant ADDR --underlay IF
  mrc-agent status  [--watch] [--json] [--state PATH]
  mrc-agent paths   [--state PATH]
  mrc-agent test    --controller URL
"""
import argparse, json, os, signal, socket, subprocess, sys, tempfile, threading, time
from urllib import request as urlreq, error as urlerr

DEFAULT_IFACE   = "mrc0"
DEFAULT_STATE   = "/run/mrc-agent.json"        # falls back to /tmp/mrc-agent.json if /run unwritable
METRICS_PERIOD  = 1.0
RECONNECT_BASE  = 1.0
RECONNECT_CAP   = 30.0
VERSION         = "0.2"

def run(cmd, check=False, capture=False):
    r = subprocess.run(cmd, shell=isinstance(cmd, str),
                       stdout=subprocess.PIPE if capture else None,
                       stderr=subprocess.PIPE if capture else None,
                       text=True)
    if check and r.returncode != 0:
        raise RuntimeError(f"cmd failed ({r.returncode}): {cmd}\n{r.stderr}")
    return r

# ---- shared agent state (single writer: the run-loop) ---------------------
class State:
    """Thread-safe-ish state object, written to disk atomically on every change.
    Single writer pattern: the SSE thread updates `profile`/`kernel`/`controller`,
    the metrics thread updates `counters`. We use a lock around the dict mutation
    and the write."""
    def __init__(self, path, agent_meta):
        self.path = path
        self.lock = threading.Lock()
        self.data = {
            "version": 1, "agent_version": VERSION,
            "agent": agent_meta,
            "controller": {
                "url": agent_meta.get("controller_url", ""),
                "status": "starting",
                "last_event_at": 0, "events_received": 0, "reconnects": 0,
            },
            "profile": None,           # last received profile (full snapshot)
            "kernel": {
                "route_dst": None, "n_paths": 0,
                "last_program_at": 0, "last_program_ok": None,
                "last_program_error": None,
            },
            "counters": {
                "iface": agent_meta.get("underlay"),
                "tx_bytes_total": 0, "rx_bytes_total": 0,
                "tx_bps_1s": 0.0, "rx_bps_1s": 0.0,
                "sampled_at": 0,
            },
        }

    def update(self, section, **kw):
        with self.lock:
            self.data.setdefault(section, {}).update(kw)
            self.data["agent"]["uptime_s"] = int(time.time() - self.data["agent"]["started_at"])
            self._flush()

    def set(self, section, value):
        with self.lock:
            self.data[section] = value
            self.data["agent"]["uptime_s"] = int(time.time() - self.data["agent"]["started_at"])
            self._flush()

    def _flush(self):
        # atomic write: write to tmp + rename
        try:
            d = os.path.dirname(self.path) or "."
            os.makedirs(d, exist_ok=True)
            fd, tmp = tempfile.mkstemp(prefix=".mrc-agent.", dir=d)
            with os.fdopen(fd, "w") as f:
                json.dump(self.data, f, indent=2)
            os.replace(tmp, self.path)
        except Exception as e:
            sys.stderr.write(f"[state] write failed: {e}\n")

def resolve_state_path(requested):
    """If the default /run path isn't writable, fall back to /tmp."""
    if requested != DEFAULT_STATE:
        return requested
    try:
        os.makedirs("/run", exist_ok=True)
        with open("/run/.mrc-agent-probe", "w") as f: f.write("ok")
        os.unlink("/run/.mrc-agent-probe")
        return "/run/mrc-agent.json"
    except (PermissionError, OSError):
        return "/tmp/mrc-agent.json"

# ---- dataplane ------------------------------------------------------------
class Dataplane:
    def __init__(self, iface, tenant_addr, underlay, dry_run=False):
        self.iface = iface; self.tenant = tenant_addr; self.underlay = underlay
        self.dry = dry_run
        self.installed_route_dst = None
        self.installed_segs = []

    def _ip(self, args):
        cmd = ["ip"] + args
        if self.dry: print("[dry] " + " ".join(cmd)); return 0, ""
        r = run(cmd, capture=True)
        if r.returncode != 0:
            sys.stderr.write(f"[ip] {' '.join(args)} -> {r.returncode}: {r.stderr.strip()}\n")
        return r.returncode, r.stderr or ""

    def bring_up(self):
        # mrc0 is a marker/identity dummy. The tenant address itself stays on
        # the underlay (eth1) where the leaf's uA SID needs it to be ND-resolvable
        # as a nexthop. Putting the address on mrc0 as well (with /128 winning
        # longest-prefix-match) routed decapped packets into the dummy and
        # silently dropped them — discovered the hard way.
        if self.dry:
            for c in [["link", "add", self.iface, "type", "dummy"],
                      ["link", "set", self.iface, "up"]]:
                self._ip(c)
            print(f"[dp:dry] {self.iface} up (marker), tenant {self.tenant} on underlay={self.underlay}")
            return
        if run(["ip", "link", "show", self.iface], capture=True).returncode != 0:
            self._ip(["link", "add", self.iface, "type", "dummy"])
        self._ip(["link", "set", self.iface, "up"])
        run("sysctl -w net.ipv6.fib_multipath_hash_policy=1 >/dev/null 2>&1", capture=True)
        print(f"[dp] {self.iface} up (marker), tenant {self.tenant} on underlay={self.underlay}")

    def tear_down(self):
        self._ip(["link", "del", self.iface])

    def _underlay_gateway(self):
        """Find an IPv6 gateway reachable via the underlay, by inspecting the
        existing route to the uSID block (installed by deploy.sh hosts).
        Linux requires `via <gw>` on each nexthop for IPv6 multipath."""
        if self.dry: return "fe80::1"
        for target in ["fc00:0000::/32", "2001:db8:cccc::/48"]:
            r = run(["ip", "-6", "route", "show", target], capture=True)
            if r.returncode != 0 or not r.stdout: continue
            toks = r.stdout.split()
            if "via" in toks:
                return toks[toks.index("via") + 1]
        return None

    def program_srv6(self, peer_dst, usid_stacks):
        """SRv6 kernel encap (single uSID or ECMP multipath). Returns (ok, err)."""
        if not peer_dst or not usid_stacks: return False, "empty profile"
        cmd = ["ip", "-6", "route", "replace", f"{peer_dst}/128"]
        if len(usid_stacks) == 1:
            cmd += ["encap", "seg6", "mode", "encap", "segs", usid_stacks[0],
                    "dev", self.underlay]
        else:
            gw = self._underlay_gateway()
            if not gw:
                err = (f"no IPv6 gateway found on {self.underlay} — IPv6 multipath "
                       f"requires `via <gw>` per nexthop")
                sys.stderr.write(f"[dp] {err}\n"); return False, err
            for u in usid_stacks:
                cmd += ["nexthop", "encap", "seg6", "mode", "encap", "segs", u,
                        "via", gw, "dev", self.underlay, "weight", "1"]
        if self.dry:
            print("[dry] " + " ".join(cmd))
        else:
            r = run(cmd, capture=True)
            if r.returncode != 0:
                sys.stderr.write(f"[dp] route program FAILED: {r.stderr.strip()}\n")
                return False, r.stderr.strip()
        self.installed_route_dst = peer_dst
        self.installed_segs = list(usid_stacks)
        kind = "ECMP" if len(usid_stacks) > 1 else "single"
        print(f"[dp] srv6 route -> {peer_dst} via {kind} ({len(usid_stacks)} path)")
        return True, None

    def clear_encap(self, peer_dst):
        """Remove any agent-installed encap route to peer_dst. Used between
        mode switches so a leftover SRv6 route doesn't shadow plain RoCE or
        app-driven UDP/STEV encap on the next mode."""
        if not peer_dst: return
        if self.dry:
            print(f"[dry] ip -6 route del {peer_dst}/128 (clear)")
        else:
            run(["ip", "-6", "route", "del", f"{peer_dst}/128"], capture=True)
        self.installed_route_dst = None
        self.installed_segs = []

# ---- counters -------------------------------------------------------------
def _stats(iface):
    try:
        with open(f"/sys/class/net/{iface}/statistics/tx_bytes") as f: tx = int(f.read())
        with open(f"/sys/class/net/{iface}/statistics/rx_bytes") as f: rx = int(f.read())
        return tx, rx
    except FileNotFoundError:
        return None, None

class MetricsPoster(threading.Thread):
    def __init__(self, controller, host, iface, state, dp, period=METRICS_PERIOD):
        super().__init__(daemon=True)
        self.controller = controller.rstrip("/"); self.host = host; self.iface = iface
        self.state = state; self.dp = dp; self.period = period
        self.stop = threading.Event()
        self.last_tx = self.last_rx = self.last_ts = None

    def run(self):
        while not self.stop.is_set():
            tx, rx = _stats(self.iface); ts = time.time()
            tx_bps = rx_bps = 0.0
            if tx is not None and self.last_tx is not None:
                dt = ts - self.last_ts
                if dt > 0:
                    tx_bps = max(0.0, (tx - self.last_tx) * 8.0 / dt)
                    rx_bps = max(0.0, (rx - self.last_rx) * 8.0 / dt)
            if tx is not None:
                self.state.update("counters", iface=self.iface,
                                  tx_bytes_total=tx, rx_bytes_total=rx,
                                  tx_bps_1s=tx_bps, rx_bps_1s=rx_bps,
                                  sampled_at=ts)
                self._post(tx_bps, rx_bps)
            self.last_tx, self.last_rx, self.last_ts = tx, rx, ts
            self.stop.wait(self.period)

    def _post(self, tx_bps, rx_bps):
        body = json.dumps({
            "host": self.host, "iface": self.iface,
            "eth_tx_bps": tx_bps, "eth_rx_bps": rx_bps,
            "routes": len(self.dp.installed_segs),
        }).encode()
        req = urlreq.Request(f"{self.controller}/api/metrics", data=body,
                             headers={"Content-Type": "application/json"})
        try: urlreq.urlopen(req, timeout=2).read()
        except (urlerr.URLError, socket.timeout): pass

# ---- SSE ------------------------------------------------------------------
def sse_subscribe(url, on_message, on_status, stop_evt):
    backoff = RECONNECT_BASE
    reconnects = -1
    while not stop_evt.is_set():
        reconnects += 1
        try:
            on_status("connecting", reconnects=reconnects)
            print(f"[sse] connecting to {url}")
            req = urlreq.Request(url, headers={"Accept": "text/event-stream"})
            # 60s read timeout — server keepalive is every 5s so we're well-padded
            with urlreq.urlopen(req, timeout=60) as resp:
                print(f"[sse] connected (HTTP {resp.status})")
                on_status("connected", reconnects=reconnects)
                backoff = RECONNECT_BASE
                buf = b""
                for line in resp:
                    if stop_evt.is_set(): break
                    if line in (b"\n", b"\r\n"):
                        for L in buf.split(b"\n"):
                            if L.startswith(b"data:"):
                                try: on_message(json.loads(L[5:].strip()))
                                except json.JSONDecodeError as e:
                                    sys.stderr.write(f"[sse] bad json: {e}\n")
                        buf = b""
                    else:
                        buf += line
        except (urlerr.URLError, socket.timeout, ConnectionResetError) as e:
            on_status("disconnected", error=str(e))
            sys.stderr.write(f"[sse] disconnected: {e} — retrying in {backoff:.0f}s\n")
        except Exception as e:
            on_status("error", error=repr(e))
            sys.stderr.write(f"[sse] error: {e!r} — retrying in {backoff:.0f}s\n")
        for _ in range(int(backoff * 10)):
            if stop_evt.is_set(): return
            time.sleep(0.1)
        backoff = min(backoff * 2, RECONNECT_CAP)

# ---- driver ---------------------------------------------------------------
def cmd_run(args):
    state_path = resolve_state_path(args.state)
    dp = Dataplane(args.iface, args.tenant, args.underlay, dry_run=args.dry_run)
    dp.bring_up()
    started = time.time()
    state = State(state_path, agent_meta={
        "host": args.host, "iface": args.iface, "tenant": args.tenant,
        "underlay": args.underlay, "controller_url": args.controller,
        "pid": os.getpid(), "started_at": started, "uptime_s": 0,
        "dry_run": bool(args.dry_run),
    })
    print(f"[agent] state -> {state_path}")

    stop = threading.Event()
    def shutdown(*_): print("[agent] stop"); stop.set()
    signal.signal(signal.SIGINT, shutdown); signal.signal(signal.SIGTERM, shutdown)

    metrics = MetricsPoster(args.controller, args.host, args.underlay, state, dp)
    metrics.start()

    def on_status(status, **kw):
        upd = {"status": status, "last_status_at": time.time()}
        if "reconnects" in kw: upd["reconnects"] = kw["reconnects"]
        if "error" in kw:      upd["last_error"] = kw["error"]
        state.update("controller", **upd)

    def on_profile(p):
        mode = (p.get("mode") or "").lower()
        flow = p.get("flow") or {}
        dst = p.get("active_dst") or flow.get("dst_addr")
        evs = p.get("active_evs") or []
        stacks = [e["usid"] for e in evs if e.get("usid")]
        if not stacks and p.get("active_usid"): stacks = [p["active_usid"]]
        # for UDP/STEV the EV itself doubles as a UDP src-port hint for apps
        ev_ports = [int(e["entropy"]) for e in evs if isinstance(e.get("entropy"), int)]

        c = state.data["controller"]
        state.update("controller",
                     events_received=c.get("events_received", 0) + 1,
                     last_event_at=time.time())
        state.set("profile", {**p, "received_at": time.time()})

        # Only the source host of the flow programs anything. The destination
        # already decaps natively via its End.DT6 SID (SRv6) or just receives
        # plain RoCEv2 (UDP/STEV/none).
        if flow.get("src") and flow.get("src") != args.host:
            print(f"[push] mode={mode} paths={len(stacks)} dst={dst} "
                  f"(this host is not the source — no programming)")
            state.update("kernel", route_dst=None, n_paths=0, last_mode=mode,
                         last_program_at=time.time(),
                         last_program_ok=None, last_program_error=None)
            return

        # Clear any stale encap from a previous mode before re-programming.
        # Without this, a leftover SRv6 route would shadow a later UDP/none mode.
        if dst:
            dp.clear_encap(dst)

        if mode == "srv6":
            if dst and stacks:
                ok, err = dp.program_srv6(dst, stacks)
            else:
                ok, err = False, "no segments"
            state.update("kernel", route_dst=dst, n_paths=len(stacks), last_mode=mode,
                         last_program_at=time.time(),
                         last_program_ok=ok, last_program_error=err)
            print(f"[push] mode=srv6 paths={len(stacks)} dst={dst} ok={ok}")

        elif mode in ("udp", "stev"):
            # No kernel encap. The MRC-aware app (rocebench) reads active_evs
            # from /run/mrc-agent.json and encodes EV in its RoCEv2 UDP source
            # port (UDP) or structured into UDP src per the STEV bit layout.
            print(f"[push] mode={mode} ev_ports={ev_ports} — state published, "
                  f"encap is app-driven (no kernel routes installed)")
            state.update("kernel", route_dst=None, n_paths=len(ev_ports),
                         last_mode=mode, last_program_at=time.time(),
                         last_program_ok=True, last_program_error=None)

        elif mode in ("none", "ipv4", ""):
            # Plain RoCEv2, no MRC. The app talks to dst as a normal IPv4 (or
            # IPv6) peer; switches L4-hash on whatever 5-tuple the app exposes.
            print(f"[push] mode={mode or 'none'} — plain RoCEv2, no MRC encap")
            state.update("kernel", route_dst=None, n_paths=0, last_mode=mode,
                         last_program_at=time.time(),
                         last_program_ok=True, last_program_error=None)

        else:
            print(f"[push] mode={mode}: unrecognized — leaving dataplane alone")
            state.update("kernel", route_dst=None, n_paths=0, last_mode=mode,
                         last_program_at=time.time(),
                         last_program_ok=False, last_program_error=f"unknown mode '{mode}'")

    try:
        sse_subscribe(f"{args.controller.rstrip('/')}/api/profile/stream",
                      on_profile, on_status, stop)
    finally:
        metrics.stop.set()
        if args.delete_iface_on_exit: dp.tear_down()

# ---- status / paths / test ------------------------------------------------
def _bps(n):
    for u, t in [("Tbps", 1e12), ("Gbps", 1e9), ("Mbps", 1e6), ("Kbps", 1e3)]:
        if n >= t: return f"{n/t:.2f} {u}"
    return f"{n:.0f} bps"

def _bytes(n):
    for u, t in [("TB", 1e12), ("GB", 1e9), ("MB", 1e6), ("KB", 1e3)]:
        if n >= t: return f"{n/t:.2f} {u}"
    return f"{n} B"

def _age(ts):
    if not ts: return "—"
    s = time.time() - ts
    if s < 1.0: return "now"
    if s < 60:  return f"{s:.1f}s ago"
    if s < 3600: return f"{int(s/60)}m {int(s%60)}s ago"
    return f"{int(s/3600)}h {int((s%3600)/60)}m ago"

def _ctrl_badge(status):
    return {
        "connected":    ("✓", "CONNECTED"),
        "connecting":   ("·", "connecting"),
        "disconnected": ("✗", "DISCONNECTED"),
        "error":        ("!", "ERROR"),
        "starting":     ("·", "starting"),
    }.get(status, ("?", status.upper() if status else "UNKNOWN"))

def _read_state(path):
    try:
        with open(path) as f: return json.load(f)
    except FileNotFoundError:
        sys.stderr.write(f"no state file at {path}; is mrc-agent running?\n")
        sys.exit(2)
    except json.JSONDecodeError as e:
        sys.stderr.write(f"state file corrupted: {e}\n"); sys.exit(2)

def _query_kernel_route(dst):
    if not dst: return ""
    try:
        r = run(["ip", "-6", "route", "show", dst], capture=True)
        return (r.stdout or "").rstrip() if r.returncode == 0 else ""
    except FileNotFoundError:
        return ""

def render_status(s):
    a = s["agent"]; c = s["controller"]; p = s.get("profile") or {}; k = s["kernel"]; m = s["counters"]
    badge, label = _ctrl_badge(c.get("status", "?"))
    lines = []
    lines.append(f"╭─ {a['iface']} · MRC virtual NIC ──────────────────────── state UP ─╮")
    lines.append(f"│  host        {a['host']}")
    lines.append(f"│  identity    {a['tenant']}")
    lines.append(f"│  underlay    {a['underlay']}")
    upt = a.get("uptime_s", 0)
    upt_str = f"{upt//3600}h {(upt%3600)//60}m {upt%60}s" if upt >= 3600 else f"{upt//60}m {upt%60}s" if upt >= 60 else f"{upt}s"
    lines.append(f"│  uptime      {upt_str}")
    if a.get("dry_run"): lines.append("│  *** DRY-RUN MODE — no kernel changes ***")
    lines.append("╰" + "─" * 65)
    lines.append("")
    lines.append(f"  CONTROLLER  {c.get('url','-')}")
    lines.append(f"    [{badge}] {label} · {c.get('events_received',0)} events received · last push {_age(c.get('last_event_at'))}")
    if c.get("reconnects", 0): lines.append(f"        reconnects: {c['reconnects']}")
    if c.get("last_error"):    lines.append(f"        last error: {c['last_error']}")
    lines.append("")
    if p:
        mode = (p.get("mode") or "-").lower()
        mp = " · multipath" if p.get("multipath") else ""
        flow = p.get("flow") or {}
        lines.append(f"  EV PROFILE  (mode {mode.upper()}{mp})")
        lines.append(f"    flow      {flow.get('src','?')} → {flow.get('dst','?')} ({flow.get('dst_addr','-')})")
        evs = p.get("active_evs") or []
        by_usid = {e.get("usid"): e for e in (p.get("evs") or []) if e.get("usid")}
        if mode == "srv6":
            if evs:
                for e in evs:
                    full = by_usid.get(e["usid"], {})
                    pid  = full.get("id", "via-?")
                    lines.append(f"    [✓] {pid:<18} EV {e['entropy']:>5}    {e['usid']}")
            else:
                lines.append("    (no active EVs)")
        elif mode in ("udp", "stev"):
            if evs:
                lines.append(f"    encap     app-driven RoCEv2/UDP — EV in UDP source port")
                for e in evs:
                    # match the EV back to its path label via the full evs list
                    pid = "via-?"
                    for full in p.get("evs") or []:
                        if full.get("entropy") == e.get("entropy"):
                            pid = full.get("id", pid); break
                    if mode == "stev":
                        lines.append(f"    [✓] {pid:<18} STEV {e['entropy']:>5}  (srcport ← STEV(path,flow))")
                    else:
                        lines.append(f"    [✓] {pid:<18} EV {e['entropy']:>5}    (srcport ← EV)")
            else:
                lines.append("    (no active EVs)")
        elif mode in ("none", "ipv4", ""):
            lines.append("    plain RoCEv2 — no MRC encap; underlay does L4-hash ECMP")
        else:
            lines.append(f"    (unrecognized mode '{mode}')")
    else:
        lines.append("  EV PROFILE  (none received yet)")
    lines.append("")
    lines.append(f"  KERNEL ROUTE  →  {k.get('route_dst','—')}")
    if k.get("route_dst"):
        kind = "ECMP" if k.get("n_paths", 0) > 1 else ("single-path" if k.get("n_paths") == 1 else "—")
        status = "OK" if k.get("last_program_ok") else ("FAILED" if k.get("last_program_ok") is False else "—")
        lines.append(f"    {kind} · {k.get('n_paths',0)} nexthop(s) · programmed {_age(k.get('last_program_at'))} · {status}")
        if k.get("last_program_error"): lines.append(f"    error: {k['last_program_error']}")
        live = _query_kernel_route(k["route_dst"])
        if live:
            lines.append("    live kernel route:")
            for L in live.splitlines(): lines.append("      " + L)
    lines.append("")
    lines.append(f"  COUNTERS  (underlay {m.get('iface','-')}; mrc0 is metadata-only)")
    lines.append(f"    tx        {_bytes(m.get('tx_bytes_total',0)):>12}    last sec   {_bps(m.get('tx_bps_1s',0))}")
    lines.append(f"    rx        {_bytes(m.get('rx_bytes_total',0)):>12}    last sec   {_bps(m.get('rx_bps_1s',0))}")
    lines.append(f"    sampled   {_age(m.get('sampled_at'))}")
    return "\n".join(lines)

def cmd_status(args):
    path = resolve_state_path(args.state)
    if args.watch:
        try:
            while True:
                sys.stdout.write("\033[2J\033[H")
                sys.stdout.write(render_status(_read_state(path)))
                sys.stdout.write("\n")
                sys.stdout.flush()
                time.sleep(args.interval)
        except KeyboardInterrupt: print()
        return
    s = _read_state(path)
    if args.json: print(json.dumps(s, indent=2))
    else:         print(render_status(s))

def cmd_paths(args):
    s = _read_state(resolve_state_path(args.state))
    p = s.get("profile") or {}
    by_usid = {e.get("usid"): e for e in (p.get("evs") or []) if e.get("usid")}
    print(f"mode={p.get('mode','-').upper()} active={len(p.get('active_evs',[]))}")
    for e in p.get("active_evs", []):
        full = by_usid.get(e["usid"], {})
        print(f"  [{full.get('id','via-?')}]  EV {e.get('entropy','?'):>5}   {e.get('usid','?')}")

def cmd_test(args):
    url = f"{args.controller.rstrip('/')}/api/profile/stream"
    print(f"[test] connecting to {url}")
    stop = threading.Event()
    def on(p):
        print(f"[test] received profile: mode={p.get('mode')} active_evs={len(p.get('active_evs',[]))}")
        stop.set()
    def st(*a, **kw): pass
    t = threading.Thread(target=sse_subscribe, args=(url, on, st, stop), daemon=True)
    t.start(); t.join(timeout=args.timeout)
    if not stop.is_set(): print("[test] timeout"); sys.exit(2)
    print("[test] OK")

# ---- monitor (rich live TUI) -----------------------------------------------
SS_BIN = "ss"
def _ss_flows(iface_addr):
    """Parse `ss -tn6 -i -o state established`. Returns flows whose local
    or peer address matches the host's tenant."""
    if not iface_addr: return []
    r = run([SS_BIN, "-tn6", "-i", "-o", "state", "established"], capture=True)
    if r.returncode != 0 or not r.stdout: return []
    flows = []; cur = None
    for line in r.stdout.splitlines():
        if not line.strip(): continue
        if line.startswith(("Recv-Q", "State", "Netid")): continue
        if not line.startswith((" ", "\t")):
            parts = line.split()
            if len(parts) < 4: continue
            try:
                local, peer = parts[-2], parts[-1]
                la, lp = local.rsplit(":", 1); pa, pp = peer.rsplit(":", 1)
                la, pa = la.strip("[]"), pa.strip("[]")
                if iface_addr not in la and iface_addr not in pa:
                    cur = None; continue
                cur = {"sport": lp, "dport": pp, "src": la, "dst": pa,
                       "cwnd": None, "rtt": None, "retr": 0, "mss": 0,
                       "bytes_sent": 0, "segs_out": 0, "segs_in": 0}
                flows.append(cur)
            except Exception: cur = None
            continue
        if cur is None: continue
        for tok in line.strip().split():
            if ":" not in tok: continue
            k, _, v = tok.partition(":")
            try:
                if k == "cwnd":        cur["cwnd"] = int(v)
                elif k == "rtt":       cur["rtt"]  = float(v.split("/")[0])
                elif k == "retrans":   cur["retr"] = int(v.split("/")[-1])
                elif k == "bytes_sent":cur["bytes_sent"] = int(v)
                elif k == "segs_out":  cur["segs_out"]   = int(v)
                elif k == "segs_in":   cur["segs_in"]    = int(v)
                elif k == "mss":       cur["mss"]        = int(v)
            except Exception: pass
    return flows

def _flow_path_seg(dst_addr, sport, dport):
    """Ask the kernel which nexthop's encap segs it would pick for this
    5-tuple. Returns the inner uSID string or None."""
    if not dst_addr: return None
    r = run(["ip","-6","route","get",dst_addr,"sport",str(sport),"dport",str(dport)],
            capture=True)
    if r.returncode != 0 or not r.stdout: return None
    out = r.stdout.strip()
    if "[" in out and "]" in out:
        return out[out.index("[")+1:out.index("]")].strip()
    return None

def _snmp6():
    out = {}
    try:
        for ln in open("/proc/net/snmp6"):
            k, _, v = ln.strip().partition(" "); v = v.strip()
            if v.isdigit() and k in (
                "Ip6InReceives","Ip6InDelivers","Ip6OutForwDatagrams",
                "Ip6InDiscards","Ip6OutDiscards","Ip6InAddrErrors",
                "Ip6InHdrErrors","Ip6InNoRoutes","Ip6InTruncatedPkts",
                "Ip6OutNoRoutes"):
                out[k] = int(v)
    except Exception: pass
    return out

def _iface_stats(iface):
    s = {}
    for k in ("tx_bytes","rx_bytes","tx_packets","rx_packets","tx_errors","rx_errors","tx_dropped","rx_dropped"):
        try: s[k] = int(open(f"/sys/class/net/{iface}/statistics/{k}").read())
        except Exception: s[k] = 0
    return s

def _bar(frac, w=22): n = int(round(max(0.0, min(1.0, frac)) * w)); return "█"*n + "░"*(w-n)
def _ucwnd(c): return f"{c/1000:.1f}K" if c and c>=1000 else (str(c) if c else "—")
def _ubps(b, dt):
    bps = (b*8.0) / max(dt, 1e-9)
    if bps >= 1e9: return f"{bps/1e9:.2f}G"
    if bps >= 1e6: return f"{bps/1e6:.1f}M"
    if bps >= 1e3: return f"{bps/1e3:.0f}K"
    return f"{bps:.0f}"

def cmd_monitor(args):
    """Live TUI: per-flow cwnd/rtt/retr, aggregate bytes/pkts, IPv6 fabric
    counters, mode-specific overlay, and per-path attribution for SRv6 ECMP.
    q to quit, r to reset deltas."""
    path = resolve_state_path(args.state)
    last_iface_snap = None; last_iface = None
    last_flow_snap = {}; last_t = time.time()
    import select, tty, termios
    # put stdin in raw cbreak so single-key input is responsive
    old_tty = None
    try:
        if sys.stdin.isatty():
            old_tty = termios.tcgetattr(sys.stdin)
            tty.setcbreak(sys.stdin.fileno())
        while True:
            s = _read_state(path)
            now = time.time(); dt = max(now - last_t, 1e-3)
            a = s["agent"]; c = s["controller"]; p = s.get("profile") or {}; k = s["kernel"]
            mode = (p.get("mode") or "").lower()
            iface = a.get("underlay", "eth1")
            iface_snap = _iface_stats(iface)
            flows = _ss_flows(a.get("tenant", ""))

            for f in flows:
                key = (f["sport"], f["dport"], f["src"], f["dst"])
                prev = last_flow_snap.get(key)
                if prev:
                    f["dbytes"] = max(f["bytes_sent"] - prev["bytes_sent"], 0)
                    f["dacks"]  = max(f["segs_in"]    - prev["segs_in"],    0)
                    f["dsegs"]  = max(f["segs_out"]   - prev["segs_out"],   0)
                    f["dretr"]  = max(f["retr"]       - prev["retr"],       0)
                else:
                    f["dbytes"] = f["dacks"] = f["dsegs"] = f["dretr"] = 0
                last_flow_snap[key] = {"bytes_sent": f["bytes_sent"],
                                       "segs_in": f["segs_in"],
                                       "segs_out": f["segs_out"],
                                       "retr": f["retr"]}
                f["path"] = None
                if mode == "srv6" and k.get("n_paths", 0) > 1 and k.get("route_dst"):
                    f["path"] = _flow_path_seg(k["route_dst"], f["sport"], f["dport"])

            if last_iface_snap and last_iface == iface:
                dtx  = max(iface_snap["tx_bytes"]   - last_iface_snap["tx_bytes"],   0)
                drx  = max(iface_snap["rx_bytes"]   - last_iface_snap["rx_bytes"],   0)
                dtxp = max(iface_snap["tx_packets"] - last_iface_snap["tx_packets"], 0)
                drxp = max(iface_snap["rx_packets"] - last_iface_snap["rx_packets"], 0)
            else:
                dtx = drx = dtxp = drxp = 0
            last_iface_snap = iface_snap; last_iface = iface; last_t = now
            sn = _snmp6()

            buf = ["\033[2J\033[H"]
            badge, lbl = _ctrl_badge(c.get("status", "?"))
            upt = a.get("uptime_s", 0)
            ustr = f"{upt//3600}h{(upt%3600)//60:02d}m" if upt>=3600 else f"{upt//60}m{upt%60:02d}s" if upt>=60 else f"{upt}s"
            mp = " · MULTIPATH" if p.get("multipath") else ""
            buf.append(f"╭─ mrc-agent · LIVE MONITOR ─── mode \033[36m{mode.upper() or '—'}\033[0m{mp} ─── q quit · r reset ─╮")
            buf.append(f"│ host       {a.get('host','-')} → {(p.get('flow') or {}).get('dst','-')}    underlay {iface}    up {ustr}")
            buf.append(f"│ ctrl       [{badge}] {lbl}    events {c.get('events_received',0)}    last push {_age(c.get('last_event_at'))}")
            if k.get("route_dst"):
                kind = "ECMP" if k.get("n_paths",0) > 1 else "single"
                buf.append(f"│ kernel     route → {k['route_dst']}  ({kind} · {k.get('n_paths',0)} path)")
            else:
                buf.append(f"│ kernel     no encap route (mode={mode or 'none'} — app-driven or plain)")
            buf.append("╰" + "─" * 86)
            buf.append("")

            evs = p.get("active_evs") or []
            buf.append(f"  ACTIVE  {len(evs)} path(s)")
            for e in evs:
                pid = "via-?"
                for full in p.get("evs") or []:
                    if full.get("entropy") == e.get("entropy"): pid = full.get("id", pid); break
                if mode == "srv6":
                    buf.append(f"    [✓] {pid:<18} EV {str(e.get('entropy','-')):>5}    \033[33m{e.get('usid','-')}\033[0m")
                elif mode in ("udp","stev"):
                    src_hint = "STEV(path,flow)" if mode=="stev" else "EV"
                    buf.append(f"    [✓] {pid:<18} EV {str(e.get('entropy','-')):>5}    udp.srcport ← {src_hint}")
                else:
                    buf.append(f"    [✓] {pid:<18} (plain RoCEv2 / no MRC)")
            buf.append("")

            buf.append(f"  FLOWS ({len(flows)} established)                                          dt={dt*1000:.0f}ms")
            buf.append("    sport  dport      cwnd     rtt(ms)  retr   acks/s   bytes/s   path")
            buf.append("    " + "─" * 80)
            for f in sorted(flows, key=lambda x: int(x.get("sport","0") or 0)):
                pp = "—"
                if f.get("path"):
                    seg = f["path"]
                    if seg.startswith("fc00:0:"):
                        rest = seg[len("fc00:0:"):]
                        pp = "sp" + rest.split(":",1)[0]
                    else: pp = seg[:8]
                rtt = f.get("rtt") or 0.0
                buf.append(f"    {f['sport']:>5}  {f['dport']:>5}  {_ucwnd(f['cwnd']):>8}   "
                           f"{rtt:>6.2f}  {f['retr']:>4}   {int(f['dacks']/dt):>6}  "
                           f"{_ubps(f['dbytes'], dt):>8}   {pp}")
            buf.append("")

            buf.append(f"  COUNTERS · underlay {iface}                                       rate over {dt*1000:.0f}ms")
            buf.append(f"    tx     {iface_snap['tx_bytes']:>14,} B  ({iface_snap['tx_packets']:>10,} pkts)   {_ubps(dtx, dt):>8}bps · {int(dtxp/dt):>6} pps")
            buf.append(f"    rx     {iface_snap['rx_bytes']:>14,} B  ({iface_snap['rx_packets']:>10,} pkts)   {_ubps(drx, dt):>8}bps · {int(drxp/dt):>6} pps")
            buf.append(f"    errors tx={iface_snap['tx_errors']} drop={iface_snap['tx_dropped']}    rx errs={iface_snap['rx_errors']} drop={iface_snap['rx_dropped']}")
            buf.append("")

            tot_acks = sum(f["segs_in"]  for f in flows)
            tot_retr = sum(f["retr"]     for f in flows)
            tot_segs = sum(f["segs_out"] for f in flows)
            d_acks   = sum(f["dacks"]    for f in flows)
            d_retr   = sum(f["dretr"]    for f in flows)
            buf.append("  TCP DERIVED                                                              /s")
            buf.append(f"    ACKs received     {tot_acks:>14,}                                  {int(d_acks/dt):>8}")
            buf.append(f"    segs sent         {tot_segs:>14,}")
            buf.append(f"    retrans (≈NACK)   {tot_retr:>14,}                                  {int(d_retr/dt):>8}")
            buf.append("    (true RoCE ACK/NACK/SACK counters require a real IB device)")
            buf.append("")

            buf.append("  IPv6 FABRIC")
            buf.append(f"    in receives     {sn.get('Ip6InReceives',0):>12,}     in delivers   {sn.get('Ip6InDelivers',0):>12,}")
            buf.append(f"    out forw        {sn.get('Ip6OutForwDatagrams',0):>12,}     in no route   {sn.get('Ip6InNoRoutes',0):>12,}")
            buf.append(f"    in discards     {sn.get('Ip6InDiscards',0):>12,}     in addr err   {sn.get('Ip6InAddrErrors',0):>12,}")
            buf.append("")

            if mode == "srv6" and k.get("n_paths",0) > 1 and flows:
                by = {}
                for f in flows:
                    pp = f.get("path") or "—"
                    by.setdefault(pp, {"bytes": 0, "n": 0})
                    by[pp]["bytes"] += f["dbytes"]; by[pp]["n"] += 1
                total = sum(v["bytes"] for v in by.values()) or 1
                buf.append("  PATH DISTRIBUTION (kernel 5-tuple hash, observed)")
                for pp, v in sorted(by.items()):
                    pct = v["bytes"] / total
                    label = pp
                    if pp and pp.startswith("fc00:0:"):
                        rest = pp[len("fc00:0:"):]
                        label = "via-sp" + rest.split(":",1)[0]
                    buf.append(f"    {label:<22} {_bar(pct):<22} {_ubps(v['bytes'], dt):>8}bps  ({pct*100:>4.1f}%)  flows={v['n']}")
                buf.append("")

            sys.stdout.write("\n".join(buf)); sys.stdout.write("\n"); sys.stdout.flush()

            if select.select([sys.stdin], [], [], args.interval)[0]:
                ch = sys.stdin.read(1)
                if ch in ("q", "Q"): break
                if ch == "r":
                    last_flow_snap.clear(); last_iface_snap = None
    except KeyboardInterrupt:
        pass
    finally:
        if old_tty is not None:
            termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old_tty)
        sys.stdout.write("\n"); sys.stdout.flush()

def main():
    ap = argparse.ArgumentParser(prog="mrc-agent")
    sub = ap.add_subparsers(dest="cmd", required=True)

    p_run = sub.add_parser("run", help="run the agent (foreground)")
    p_run.add_argument("--host", required=True)
    p_run.add_argument("--controller", required=True)
    p_run.add_argument("--tenant", required=True)
    p_run.add_argument("--underlay", default="eth1")
    p_run.add_argument("--iface", default=DEFAULT_IFACE)
    p_run.add_argument("--state", default=DEFAULT_STATE,
                       help=f"state file path (default {DEFAULT_STATE}, falls back to /tmp)")
    p_run.add_argument("--dry-run", action="store_true")
    p_run.add_argument("--delete-iface-on-exit", action="store_true")
    p_run.set_defaults(func=cmd_run)

    p_st = sub.add_parser("status", help="rich view of the running agent (reads local state file)")
    p_st.add_argument("--state", default=DEFAULT_STATE)
    p_st.add_argument("--watch", action="store_true", help="refresh every --interval seconds")
    p_st.add_argument("--interval", type=float, default=1.0)
    p_st.add_argument("--json", action="store_true")
    p_st.set_defaults(func=cmd_status)

    p_pa = sub.add_parser("paths", help="just the active paths")
    p_pa.add_argument("--state", default=DEFAULT_STATE)
    p_pa.set_defaults(func=cmd_paths)

    p_te = sub.add_parser("test", help="one-shot SSE connection test")
    p_te.add_argument("--controller", required=True)
    p_te.add_argument("--timeout", type=float, default=5.0)
    p_te.set_defaults(func=cmd_test)

    p_mon = sub.add_parser("monitor", help="live TUI: flows, ACKs, retr, per-path attribution")
    p_mon.add_argument("--state", default=DEFAULT_STATE)
    p_mon.add_argument("--interval", type=float, default=0.5)
    p_mon.set_defaults(func=cmd_monitor)

    args = ap.parse_args()
    args.func(args)

if __name__ == "__main__":
    main()
